[sub_resource type="GDScript" id="GDScript_0tmw4"]
script/source = "extends EnemyState

const STEP_SOUND = preload(\"res://assets/enemy/sounds/step_sfx_enemy.tres\")

func play_step():
	SFX.play(STEP_SOUND, enemy)
"

